# syntax=docker/dockerfile:1.7

# ═══════════════════════════════════════════════════════════════════════════════
# Multi-stage build: deps → builder → runner
# Each stage starts from a fresh image; only what we explicitly COPY across
# ends up in the next stage. The final image only contains the runner stage.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Stage 1: install dependencies ─────────────────────────────────────────────
# We split deps into their own stage so it's cached separately from the build.
# When only source changes, `npm ci` doesn't run again.
FROM node:22-alpine AS deps
WORKDIR /app

# Copy lockfile + manifest first so this layer caches on dep changes only.
COPY package.json package-lock.json ./
# `npm ci` (not `npm install`) — uses the lockfile exactly, no version drift.
RUN npm ci


# ── Stage 2: build the Next.js production bundle ──────────────────────────────
FROM node:22-alpine AS builder
WORKDIR /app

# Reuse the node_modules from the deps stage (no reinstall).
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# NEXT_PUBLIC_* values are baked in at build time, not runtime. The default
# here lets the image work standalone; Compose / ECS will override it.
ARG NEXT_PUBLIC_API_URL=http://localhost:8000
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

# Skip telemetry pings during the build (faster + no network surprises).
ENV NEXT_TELEMETRY_DISABLED=1

# Produces .next/standalone (server.js + minimal deps) and .next/static (assets).
RUN npm run build


# ── Stage 3: tiny runtime image ───────────────────────────────────────────────
FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0

# Non-root user for runtime, same security reasoning as the backend.
RUN addgroup -S app && adduser -S app -G app

# `output: "standalone"` produces .next/standalone with its own minimal
# node_modules. We copy that, plus .next/static (the public CSS/JS bundle)
# and the public/ folder (favicon etc.).
COPY --from=builder --chown=app:app /app/.next/standalone ./
COPY --from=builder --chown=app:app /app/.next/static ./.next/static
COPY --from=builder --chown=app:app /app/public ./public

USER app

EXPOSE 3000

# server.js is generated by `next build` when output:'standalone' is set.
CMD ["node", "server.js"]
